<export table-id="tblStdPerAtt" header-row="true">
  <filter field="patDate" format="MM/dd/yyyy" operator="greaterOrEqual" source="session" value="currentContext.startDate"/>
  <filter field="patCodeView" operator="equals" source="default" value="AD" connector="and"/>
  <filter field="patCodeView" operator="equals" source="default" value="AD-E" connector="and"/>

  <field id="patDate" header-source="constant" header-value="AbsenceDate" />
  <field id="relPatStdOid.stdIDLocal" header-source="constant" header-value="StudentPupilNumber" />
  <field id="relPatMstOid.relMstCskOid.relCskCrsOid.crsCourseDesc" header-source="constant" header-value="Section" />
  <field id="relPatMstOid.relMstStfPrim.stfStaffID" header-source="constant" header-value="SectionTeacher" />
  <field id="patCodeView" header-source="constant" header-value="Code" />
</export>
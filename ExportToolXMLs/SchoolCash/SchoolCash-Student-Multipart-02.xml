<export table-id="tblStdContact" header-row="true" value-wrapper="">
  <!-- Only export contacts with portal access set to yes -->
  <filter field="ctjPortalAcs" operator="equals" value="1" />
  <filter field="relCtjCntOid.relCntPsnOid.psnEmail01" operator="notEmpty" />

  <field id="relCtjStdOid.stdIDLocal" header-source="constant" header-value="StudentPupilNo" />
  <field id="relCtjCntOid.relCntPsnOid.psnEmail01" header-source="constant" header-value="Email" />
</export>

